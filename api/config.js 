export default function handler(req, res) {
  // These come from Vercel Environment Variables — never exposed in your code
  const url = process.env.SUPABASE_URL;
  const key = process.env.SUPABASE_KEY;

  if (!url || !key) {
    return res.status(500).json({ error: 'Environment variables SUPABASE_URL and SUPABASE_KEY are not set in Vercel.' });
  }

  // Allow the HTML page to fetch this
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.status(200).json({ url, key });
}